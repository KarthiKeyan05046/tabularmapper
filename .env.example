# Copy to `.env` and fill in. NEVER commit the real .env (it's gitignored).
# Load it with `uv run --env-file .env ...`, or `load_dotenv()` in your app.

# --- Storage backends (URL-selected; secrets belong here, not in code) ---

# Mapping cache. Default is a local SQLite file if unset. Use redis:// or
# postgresql:// (with TLS: rediss://) to share a cache across workers.
BANK_MAPPER_CACHE=sqlite:///mapping_cache.db
# BANK_MAPPER_CACHE=rediss://default:PASSWORD@your-host.redis.io:6379
# BANK_MAPPER_CACHE=postgresql://user:PASSWORD@host:5432/dbname

# Self-learning vocabulary store (same URL scheme). Default SQLite if unset.
BANK_MAPPER_LEARN_STORE=sqlite:///learned_synonyms.db
# BANK_MAPPER_LEARN_STORE=rediss://default:PASSWORD@your-host.redis.io:6379

# Output template + synonyms config (file / https:// / s3://). Default built-in.
# BANK_MAPPER_CONFIG=./config.json

# --- AI column matcher (only needed for --ai / table_matcher) ---

OPENAI_API_KEY=sk-your-key-here

# Optional — defaults shown. Any OpenAI-compatible endpoint
# (OpenAI, Azure, Together, Groq, local vLLM / Ollama / LM Studio).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Examples for other providers:
# OPENAI_BASE_URL=http://localhost:11434/v1     # Ollama (OPENAI_API_KEY can be any string)
# OPENAI_MODEL=llama3.1
