# Copy to `.env` and fill in. NEVER commit the real .env (it's gitignored).
# Load it with `uv run --env-file .env ...`, or `load_dotenv()` in your app.

# --- Storage backends (URL-selected; secrets belong here, not in code) ---

# Mapping cache. DEFAULT is in-memory (no files) if unset. Set a URL to persist:
# a SQLite path, or redis:// / valkeys:// / postgresql:// to share across workers.
# TABULARMAPPER_CACHE=sqlite:///mapping_cache.db
# TABULARMAPPER_CACHE=rediss://default:PASSWORD@your-host.redis.io:6379
# TABULARMAPPER_CACHE=valkeys://default:PASSWORD@your-host.aivencloud.com:PORT  # Aiven Valkey (TLS)
# TABULARMAPPER_CACHE=postgresql://user:PASSWORD@host:5432/dbname

# Self-learning vocabulary store (same URL scheme). DEFAULT in-memory if unset.
# TABULARMAPPER_LEARN_STORE=sqlite:///learned_synonyms.db
# TABULARMAPPER_LEARN_STORE=rediss://default:PASSWORD@your-host.redis.io:6379

# Output template + synonyms config (file / https:// / s3://). Default built-in.
# TABULARMAPPER_CONFIG=./config.json

# Fuzzy-accept gate 0-100 (default 80). Raise it to send borderline fuzzy
# matches to the AI matcher instead of trusting them. Per-request override:
# POST /mapper/map?threshold=90
# TABULARMAPPER_THRESHOLD=80

# --- AI column matcher (only needed for --ai / table_matcher) ---

OPENAI_API_KEY=sk-your-key-here

# Optional — defaults shown. Any OpenAI-compatible endpoint
# (OpenAI, Azure, Together, Groq, local vLLM / Ollama / LM Studio).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Examples for other providers:
# OPENAI_BASE_URL=http://localhost:11434/v1     # Ollama (OPENAI_API_KEY can be any string)
# OPENAI_MODEL=llama3.1
