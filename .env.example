# Copy to `.env` and fill in. NEVER commit the real .env (it's gitignored).
# Only needed for the --ai / table_matcher path.

# Required for --ai
OPENAI_API_KEY=sk-your-key-here

# Optional — defaults shown. Point these at any OpenAI-compatible endpoint
# (OpenAI, Azure, Together, Groq, local vLLM / Ollama / LM Studio).
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Examples for other providers:
# OPENAI_BASE_URL=http://localhost:11434/v1     # Ollama (OPENAI_API_KEY can be any string)
# OPENAI_MODEL=llama3.1
